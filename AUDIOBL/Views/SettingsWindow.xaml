<Window x:Class="AUDIOBL.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FF1A1A2E">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize"   Value="13"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#FFAAAACC"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Padding"    Value="0,0,0,4"/>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize"   Value="13"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize"   Value="13"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background"  Value="#FF2A2A4E"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="BorderBrush" Value="#FF4A4A8E"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="Padding"     Value="6,4"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="28,24,28,24" MinWidth="320">
        <TextBlock FontSize="20" FontWeight="Bold" Margin="0,0,0,24">AUDIOBL</TextBlock>

        <!-- Language -->
        <Label x:Name="LangLabel" Margin="0,0,0,6"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,20" x:Name="LangPanel">
            <RadioButton x:Name="LangAutoRadio" GroupName="Lang" Margin="0,0,20,0"
                         Checked="LangRadio_Changed"/>
            <RadioButton x:Name="LangFrRadio"   GroupName="Lang" Margin="0,0,20,0"
                         Checked="LangRadio_Changed"/>
            <RadioButton x:Name="LangEnRadio"   GroupName="Lang"
                         Checked="LangRadio_Changed"/>
        </StackPanel>

        <!-- Device name -->
        <Label x:Name="DeviceLabel" Margin="0,0,0,4"/>
        <TextBox x:Name="DeviceBox" Margin="0,0,0,20"
                 LostFocus="DeviceBox_LostFocus"/>

        <!-- Auto-start -->
        <CheckBox x:Name="AutoStartCheck"
                  Checked="AutoStartCheck_Changed" Unchecked="AutoStartCheck_Changed"/>
    </StackPanel>
</Window>
